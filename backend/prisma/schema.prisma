generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id        Int      @id @default(autoincrement())
  phoneNo   String   @unique
  area      String?
  olt       String?
  createdAt DateTime @default(now())

  billings  Billing[]
}

model Billing {
  id               Int      @id @default(autoincrement())
  phoneNo          String
  invoiceAmount    Float?
  taxAmount        Float?
  totalAmount      Float?
  paidAmount       Float?
  revenueRealized  Float?
  commission       Float?
  createdAt        DateTime @default(now())

  customer Customer @relation(fields: [phoneNo], references: [phoneNo])
}

model Ticket {
  id         Int      @id @default(autoincrement())
  phoneNo    String
  issue      String
  status     String   @default("OPEN")
  assignedTo Int?
  createdAt  DateTime @default(now())
}

model Technician {
  id   Int    @id @default(autoincrement())
  name String
}